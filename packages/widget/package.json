{
  "name": "@skillhub/widget",
  "version": "1.0.0",
  "description": "SkillHub 嵌入式组件 - 为您的应用集成 Skill 搜索和管理功能",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --external react --external @skillhub/search-sdk",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch --external react --external @skillhub/search-sdk",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "skillhub",
    "widget",
    "skill-store",
    "embedded",
    "react-component"
  ],
  "author": "SkillHub Team",
  "license": "MIT",
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "@skillhub/search-sdk": ">=1.0.0"
  },
  "dependencies": {
    "lucide-react": "^0.263.1"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "tsup": "^8.0.0",
    "@types/react": "^18.0.0",
    "@types/node": "^20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/skillhub/skillhub.git",
    "directory": "packages/widget"
  },
  "homepage": "https://github.com/skillhub/skillhub/tree/main/packages/widget#readme",
  "bugs": {
    "url": "https://github.com/skillhub/skillhub/issues"
  }
}
