# ============================================
# SkillHub 生产环境配置
# ============================================
# ⚠️ 重要安全提示:
# 1. 不要将此文件提交到版本控制系统
# 2. 使用强密码和密钥
# 3. 定期轮换敏感凭证
# 4. 限制环境变量访问权限
# ============================================

# 复制此文件为 .env.production 并填入实际值
# cp .env.production.example .env.production

# ============================================
# 数据库配置
# ============================================
# ⚠️ 必须修改默认密码！
# 生成强密码: openssl rand -base64 32
DATABASE_URL="postgresql://skillhub:<STRONG_PASSWORD>@db:5432/skillhub?schema=public"

# ============================================
# NextAuth 认证配置
# ============================================
# ⚠️ 必须生成新的密钥！
# 生成密钥: openssl rand -base64 32
NEXTAUTH_SECRET="<GENERATE_NEW_SECRET_KEY>"

# 生产环境的完整 URL（必须使用 HTTPS）
NEXTAUTH_URL="https://skillhub.proclaw.cc"

# ============================================
# GitHub OAuth 配置
# ============================================
# 在 https://github.com/settings/developers 创建生产环境 OAuth App
# Authorization callback URL: http://8.136.122.123:3000/oauth/callback?provider=github
GITHUB_CLIENT_ID="<YOUR_PRODUCTION_GITHUB_CLIENT_ID>"
GITHUB_CLIENT_SECRET="<YOUR_PRODUCTION_GITHUB_CLIENT_SECRET>"

# ============================================
# 自签 Session JWT 密钥（GitHub OAuth 需要）
# ============================================
# 生成命令: openssl rand -hex 32
# 至少 32 字符，用于签发和验证 GitHub 登录的 HS256 JWT
SESSION_SECRET="<GENERATE_64_CHAR_HEX_STRING>"

# ============================================
# 应用 URL 配置
# ============================================
# 阿里云 ECS IP 部署
NEXT_PUBLIC_APP_URL="http://8.136.122.123:3000"

# ============================================
# NvwaX OIDC 配置
# ============================================
SKILLHUB_OIDC_CLIENT_ID="skillhub-web"
SKILLHUB_OIDC_DISCOVERY_URL="https://account.proclaw.cc/.well-known/openid-configuration"

# ============================================
# Session Cookie 配置（IP 部署）
# ============================================
# IP 部署不需要跨子域，保持 lax 即可
SESSION_COOKIE_SAMESITE="lax"
# HTTP 部署需设为 false（配置 HTTPS 后改为 true）
SESSION_COOKIE_SECURE="false"

# ============================================
# Redis 缓存（可选，用于速率限制和缓存）
# ============================================
REDIS_URL="redis://redis:6379"

# ============================================
# AI Embeddings 配置（语义搜索功能）
# ============================================
# 支持多个提供商：OpenAI、智谱AI、DeepSeek
# 
# 选项 1: 智谱AI (推荐，性价比高)
# 获取 API Key: https://open.bigmodel.cn/usercenter/apikeys
OPENAI_API_KEY="your-zhipu-api-key"
OPENAI_BASE_URL="https://open.bigmodel.cn/api/paas/v4"
#
# 选项 2: DeepSeek
# OPENAI_API_KEY="your-deepseek-api-key"
# OPENAI_BASE_URL="https://api.deepseek.com"
#
# 选项 3: OpenAI
# OPENAI_API_KEY="your-openai-api-key"
# OPENAI_BASE_URL="https://api.openai.com/v1" (默认，可不设置)

# ============================================
# 应用配置
# ============================================
NODE_ENV="production"
PORT=3000

# ============================================
# 文件上传配置
# ============================================
MAX_FILE_SIZE=10485760  # 10MB
UPLOAD_DIR="/app/public/uploads"

# ============================================
# CORS 配置
# ============================================
# 仅允许信任的域名（逗号分隔）
ALLOWED_ORIGINS="https://skillhub.proclaw.cc"

# ============================================
# 速率限制配置
# ============================================
# API 请求限制（每分钟）
RATE_LIMIT_MAX=100

# ============================================
# 监控和日志
# ============================================
# Sentry 错误追踪（推荐配置）
# SENTRY_DSN="https://xxx@xxx.ingest.sentry.io/xxx"

# 日志级别: error, warn, info, debug
LOG_LEVEL="info"

# ============================================
# 备份配置（可选）
# ============================================
# BACKUP_DIR="/backups/postgres"
# BACKUP_RETENTION_DAYS=7
# AWS_S3_BUCKET="skillhub-backups"  # 用于云存储备份
