generator client {
  provider        = "prisma-client-js"
  binaryTargets   = ["native", "rhel-openssl-3.0.x"]
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String            @id @default(uuid())
  email              String            @unique
  name               String?
  image              String?
  emailVerified      DateTime?
  role               UserRole          @default(USER)
  isDisabled         Boolean           @default(false)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  password           String?
  resetToken         String?
  resetTokenExpiry   DateTime?
  accounts           Account[]
  apiKeys            ApiKey[]
  auditLogs          AuditLog[]
  namespaces         NamespaceMember[]
  ownedNamespaces    Namespace[]       @relation("NamespaceOwner")
  reviews            Review[]
  sessions           Session[]
  feedbacks          SkillFeedback[]
  skills             Skill[]

  @@map("users")
}

model Skill {
  id               String          @id @default(uuid())
  name             String
  description      String
  version          String
  category         String
  tags             String[]
  screenshots      String[]
  status           SkillStatus     @default(DRAFT)
  authorId         String
  createdAt        DateTime        @default(now())
  currency         String          @default("CNY")
  downloadCount    Int             @default(0)
  iconUrl          String?
  isPublic         Boolean         @default(false)
  namespaceId      String?
  packageUrl       String?
  price            Decimal         @default(0) @db.Decimal(10, 2)
  rating           Float           @default(0)
  readme           String?
  reviewCount      Int             @default(0)
  slug             String          @unique
  updatedAt        DateTime        @updatedAt
  authorName       String?
  authorUrl        String?
  compatibility    Json?
  confidence       Float           @default(70)
  dependencies     Json?
  documentationUrl String?
  languages        String[]
  lastSyncedAt     DateTime?
  permissions      Json?
  qualityScore     Float           @default(0)
  repositoryUrl    String?
  source           String?
  sourceId         String?
  sourceUrl        String?
  starCount        Int             @default(0)
  subcategory      String?
  syncStatus       String?
  embedding        Json?           // OpenAI embeddings (存储为JSON数组，向后兼容)
  embeddingVector  Float[]         // pgvector格式 (维度1536，用于高性能向量搜索)
  reviews          Review[]
  feedbacks        SkillFeedback[]
  versions         SkillVersion[]
  author           User            @relation(fields: [authorId], references: [id])
  namespace        Namespace?      @relation(fields: [namespaceId], references: [id])

  @@index([slug])
  @@index([category])
  @@index([status])
  @@index([source])
  @@index([sourceId])
  @@index([qualityScore(sort: Desc)])
  @@index([updatedAt(sort: Desc)])
  @@map("skills")
}

model SkillVersion {
  id         String   @id @default(uuid())
  version    String
  changelog  String?
  createdAt  DateTime @default(now())
  manifest   Json
  packageUrl String
  skillId    String
  skill      Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@index([skillId])
  @@map("skill_versions")
}

model Namespace {
  id                 String            @id @default(uuid())
  name               String
  slug               String            @unique
  description        String?
  visibility         String            @default("public")
  allowPublicPublish Boolean           @default(false)
  avatarUrl          String?
  createdAt          DateTime          @default(now())
  downloadCount      Int               @default(0)
  memberCount        Int               @default(1)
  ownerId            String
  skillCount         Int               @default(0)
  updatedAt          DateTime          @updatedAt
  type               NamespaceType
  members            NamespaceMember[]
  policy             NamespacePolicy?
  owner              User              @relation("NamespaceOwner", fields: [ownerId], references: [id])
  skills             Skill[]

  @@index([slug])
  @@map("namespaces")
}

model NamespaceMember {
  invitedBy   String?
  joinedAt    DateTime      @default(now())
  namespaceId String
  userId      String
  role        NamespaceRole
  namespace   Namespace     @relation(fields: [namespaceId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([namespaceId, userId])
  @@map("namespace_members")
}

model NamespacePolicy {
  allowedVersions    String[]  @default(["*"])
  autoApproveMembers Boolean   @default(false)
  maxPackageSizeMb   Int       @default(50)
  namespaceId        String    @id
  requireReview      Boolean   @default(true)
  updatedAt          DateTime  @updatedAt
  namespace          Namespace @relation(fields: [namespaceId], references: [id], onDelete: Cascade)

  @@map("namespace_policies")
}

model Review {
  id              String        @id @default(uuid())
  skillId         String
  version         String
  status          ReviewStatus  @default(PENDING_REVIEW)
  previousStatus  ReviewStatus?
  reviewerId      String?
  reviewNotes     String?
  rejectionReason String?
  automatedChecks Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  completedAt     DateTime?
  reviewer        User?         @relation(fields: [reviewerId], references: [id])
  skill           Skill         @relation(fields: [skillId], references: [id])

  @@index([skillId])
  @@index([status])
  @@map("reviews")
}

model AuditLog {
  id           String   @id @default(uuid())
  action       String
  metadata     Json?
  changes      Json?
  status       String   @default("success")
  actorId      String?
  actorIp      String?
  createdAt    DateTime @default(now())
  errorMessage String?
  resourceId   String
  resourceType String
  userAgent    String?
  actor        User?    @relation(fields: [actorId], references: [id])

  @@index([actorId])
  @@index([resourceType, resourceId])
  @@index([action])
  @@index([createdAt(sort: Desc)])
  @@map("audit_logs")
}

model Account {
  id                String  @id @default(uuid())
  type              String
  provider          String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  providerAccountId String
  userId            String
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid())
  expires      DateTime
  sessionToken String   @unique
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model ApiKey {
  id          String    @id @default(uuid())
  userId      String
  name        String
  keyHash     String
  prefix      String
  permissions String[]  @default(["read"])
  expiresAt   DateTime?
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([prefix])
  @@map("api_keys")
}

model SyncLog {
  id           String    @id @default(uuid())
  source       String
  startedAt    DateTime  @default(now())
  completedAt  DateTime?
  totalCount   Int       @default(0)
  successCount Int       @default(0)
  failedCount  Int       @default(0)
  status       String    @default("running")
  errorMessage String?
  metadata     Json?

  @@index([source])
  @@index([startedAt(sort: Desc)])
  @@map("sync_logs")
}

model CrawlerTask {
  id           String    @id @default(uuid())
  taskType     String
  target       String
  status       String    @default("pending")
  priority     Int       @default(1)
  retryCount   Int       @default(0)
  maxRetries   Int       @default(3)
  scheduledAt  DateTime?
  startedAt    DateTime?
  completedAt  DateTime?
  errorMessage String?
  result       Json?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([status])
  @@index([scheduledAt])
  @@index([createdAt(sort: Desc)])
  @@map("crawler_tasks")
}

model SkillFeedback {
  id                   String   @id @default(uuid())
  skillId              String
  userId               String?
  feedbackType         String
  currentCategory      String?
  suggestedCategory    String?
  currentSubcategory   String?
  suggestedSubcategory String?
  reason               String
  status               String   @default("pending")
  adminNotes           String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  skill                Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)
  user                 User?    @relation(fields: [userId], references: [id])

  @@index([skillId])
  @@index([userId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("skill_feedbacks")
}

model CrawlerConfig {
  id          String   @id @default(uuid())
  configKey   String   @unique
  configValue Json
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([configKey])
  @@map("crawler_configs")
}

model playing_with_neon {
  id    Int    @id @default(autoincrement())
  name  String
  value Float? @db.Real
}

enum SkillStatus {
  DRAFT
  PENDING_REVIEW
  UNDER_REVIEW
  APPROVED
  REJECTED
  ARCHIVED
}

enum NamespaceType {
  PERSONAL
  TEAM
  GLOBAL
}

enum NamespaceRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum ReviewStatus {
  DRAFT
  PENDING_REVIEW
  UNDER_REVIEW
  AUTO_APPROVED
  APPROVED
  REJECTED
  REQUIRES_CHANGES
  ARCHIVED
}

enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN
}
