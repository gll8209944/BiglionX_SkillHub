# ============================================
# SkillHub 生产环境配置示例
# ============================================
# 复制此文件为 .env.production 并填入实际值

# ============================================
# 站点配置
# ============================================
NEXT_PUBLIC_APP_URL="https://skillhub.proclaw.cc"

# ============================================
# NvwaX OIDC 认证配置（Public Client）
# ============================================
# 生产环境使用 NvwaX 官方 IdP
SKILLHUB_OIDC_DISCOVERY_URL="https://account.proclaw.cc/.well-known/openid-configuration"
# SKILLHUB_OIDC_CLIENT_ID="skillhub-web"  # 默认值，生产无需覆盖

# ============================================
# Session Cookie 跨域配置（SSO 静默登录）
# ============================================
# 与主站 account.proclaw.cc 共享会话必须 SameSite=None; Secure
SESSION_COOKIE_SAMESITE="none"
SESSION_COOKIE_SECURE="true"

# ============================================
# 数据库（Neon）
# ============================================
DATABASE_URL="postgresql://user:password@ep-xxx-xxx.region.aws.neon.tech/skillhub?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxx-xxx.region.aws.neon.tech/skillhub?sslmode=require"

# ============================================
# Node 环境
# ============================================
NODE_ENV="production"
