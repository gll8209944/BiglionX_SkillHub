{
  "buildCommand": "cd ../.. && npm run build",
  "outputDirectory": ".next",
  "installCommand": "cd ../.. && npm ci",
  "framework": "nextjs",
  "regions": ["sin1"],
  "env": {
    "NODE_ENV": "production",
    "PRISMA_GENERATE_SKIP_AUTOINSTALL": "true"
  },
  "build": {
    "env": {
      "CYPRESS_INSTALL_BINARY": "0"
    }
  },
  "crons": [
    {
      "path": "/api/cron/crawler",
      "schedule": "0 19 * * *"
    }
  ]
}
