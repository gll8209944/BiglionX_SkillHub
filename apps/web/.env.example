# ============================================
# Skill Hub 环境变量配置示例
# ============================================
# 复制此文件为 .env.local 并填入实际值
cp .env.example .env.local

# ============================================
# 站点配置
# ============================================
# 应用公开 URL（用于 SEO、Canonical URL、Sitemap 等）
# 生产部署时务必设置为实际域名
# NEXT_PUBLIC_APP_URL="https://skillhub.proclaw.cc"

# ============================================
# 数据库配置 - Neon (Serverless PostgreSQL)
# ============================================
# 从 https://console.neon.tech 获取连接字符串
# 格式: postgresql://user:password@ep-xxx-xxx.region.aws.neon.tech/dbname?sslmode=require

DATABASE_URL="postgresql://user:password@ep-xxx-xxx.region.aws.neon.tech/skillhub?sslmode=require"

# 直接连接 URL（用于 Prisma Migrate）
# 在 Neon Dashboard -> Connection Details 中获取直连地址
DIRECT_URL="postgresql://user:password@ep-xxx-xxx.region.aws.neon.tech/skillhub?sslmode=require"

# ============================================
# NextAuth 认证配置
# ============================================
# 生成密钥: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-change-in-production-use-openssl-rand-base64-32"

# 应用 URL（开发环境）
NEXTAUTH_URL="http://localhost:3000"

# 生产环境取消注释
# NEXTAUTH_URL="https://skillhub.proclaw.cc"

# ============================================
# NvwaX OIDC 认证配置（Public Client）
# ============================================
# NvwaX 分配给 SkillHub 的公共 client_id
# 默认 'skillhub-web'，通常无需覆盖；dev/staging 需要不同 RP 时才设置
# SKILLHUB_OIDC_CLIENT_ID="skillhub-web"

# Discovery 文档 URL（默认 NvwaX 官方地址，仅测试/灰度需要覆盖）
# SKILLHUB_OIDC_DISCOVERY_URL="https://account.proclaw.cc/.well-known/openid-configuration"

# 公开应用 URL（用于拼接 redirect_uri，与 NEXTAUTH_URL 保持一致）
# redirect_uri 由 `${NEXT_PUBLIC_APP_URL}/oauth/callback` 拼接，
# 必须与 NvwaX IdP（account.proclaw.cc）数据库中为 SkillHub 注册的回调路径严格匹配
# 本地开发：http://localhost:3000
# 生产：https://skillhub.proclaw.cc
# NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ============================================
# Session Cookie 配置（可选）
# ============================================
# 生产环境启用跨子域 SSO 时设置（与主站共享会话需要）
# SESSION_COOKIE_SAMESITE="none"   # 默认 lax；跨子域 SSO 需 none
# SESSION_COOKIE_SECURE="true"     # 默认生产 true，开发 false

# ============================================
# GitHub OAuth 配置
# ============================================
# 在 https://github.com/settings/developers 创建 OAuth App
# Authorization callback URL: http://localhost:3000/oauth/callback?provider=github

GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"

# ============================================
# 自签 Session JWT 密钥（GitHub OAuth 需要）
# ============================================
# 生成命令: openssl rand -hex 32
# 至少 32 字符，用于签发和验证 GitHub 登录的 HS256 JWT
SESSION_SECRET=""

# ============================================
# Redis 缓存（可选）
# ============================================
# 使用 Upstash: https://upstash.com
REDIS_URL="redis://default:password@xxx.upstash.io:6379"

# ============================================
# 存储配置 - Supabase Storage
# ============================================
# 在 https://supabase.com 创建项目
SUPABASE_URL="https://xxx.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ============================================
# 邮件服务配置
# ============================================
# 选项 1: 使用 Resend (推荐)
# 在 https://resend.com 注册
RESEND_API_KEY="re_xxx"
EMAIL_FROM="noreply@skillhub.proclaw.cc"

# 选项 2: 使用 SMTP 服务器（QQ邮箱、Gmail等）
# QQ邮箱配置示例：
# EMAIL_SERVER_HOST="smtp.qq.com"
# EMAIL_SERVER_PORT="465"
# EMAIL_SERVER_USER="your-email@qq.com"
# EMAIL_SERVER_PASSWORD="your-smtp-authorization-code"  # 注意：使用授权码，不是登录密码
# EMAIL_FROM="your-email@qq.com"

# Gmail 配置示例：
# EMAIL_SERVER_HOST="smtp.gmail.com"
# EMAIL_SERVER_PORT="587"
# EMAIL_SERVER_USER="your-email@gmail.com"
# EMAIL_SERVER_PASSWORD="your-app-password"  # 需要开启两步验证后生成应用专用密码
# EMAIL_FROM="your-email@gmail.com"

# 163邮箱配置示例：
# EMAIL_SERVER_HOST="smtp.163.com"
# EMAIL_SERVER_PORT="465"
# EMAIL_SERVER_USER="your-email@163.com"
# EMAIL_SERVER_PASSWORD="your-authorization-code"
# EMAIL_FROM="your-email@163.com"

# ============================================
# 支付配置（后续添加）
# ============================================
# 支付宝
ALIPAY_APP_ID=""
ALIPAY_PRIVATE_KEY=""
ALIPAY_PUBLIC_KEY=""

# 微信支付
WECHAT_PAY_APP_ID=""
WECHAT_PAY_MCH_ID=""
WECHAT_PAY_API_KEY=""

# ============================================
# 监控和日志
# ============================================
# Sentry 错误追踪
SENTRY_DSN=""

# ============================================
# 其他配置
# ============================================
# Node 环境
NODE_ENV="development"

# 日志级别
LOG_LEVEL="info"

# API 速率限制（请求数/分钟）
RATE_LIMIT_MAX="100"

# ============================================
# 管理员配置
# ============================================
# 管理员邮箱列表（逗号分隔，用于权限控制）
# 示例: ADMIN_EMAILS=admin@example.com,superadmin@example.com
ADMIN_EMAILS=""
