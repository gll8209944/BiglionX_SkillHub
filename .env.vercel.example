# ==========================================
# SkillHub Vercel 环境变量配置
# ==========================================
# 在 Vercel Dashboard 中配置这些变量
# Settings → Environment Variables

# ---------- 数据库配置 (Neon) ----------
DATABASE_URL=postgresql://user:password@ep-xxx-xxx.region.aws.neon.tech/neondb?sslmode=require

# ---------- Redis 配置 (Upstash) ----------
# 需要在 https://upstash.com 注册并创建数据库
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token_here

# 本地开发时使用（可选）
REDIS_URL=redis://localhost:6379

# ---------- NextAuth 配置 ----------
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=https://your-project.vercel.app

# ---------- NvwaX OIDC 认证（Public Client，与 Sprint 1 契约对齐） ----------
SKILLHUB_OIDC_CLIENT_ID=skillhub-web
SKILLHUB_OIDC_DISCOVERY_URL=https://account.example.com/.well-known/openid-configuration

# ---------- Session Cookie 跨域配置（SSO 静默登录必须） ----------
SESSION_COOKIE_SAMESITE=none
SESSION_COOKIE_SECURE=true

# ---------- Node 环境 ---
NODE_ENV=production

# ---------- 可选：API Keys ----------
# OPENAI_API_KEY=sk-...
# ZHIPU_API_KEY=...
# GITHUB_TOKEN=ghp_...
# SKILLSMP_API_KEY=sk_live_...
