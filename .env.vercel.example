# ==========================================
# SkillHub Vercel 环境变量配置
# ==========================================
# 在 Vercel Dashboard 中配置这些变量
# Settings → Environment Variables

# ---------- 数据库配置 (Neon) ----------
DATABASE_URL=postgresql://neondb_owner:npg_bk4AgQRL3WYd@ep-aged-dew-a17sn40r.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# ---------- Redis 配置 (Upstash) ----------
# 需要在 https://upstash.com 注册并创建数据库
UPSTASH_REDIS_REST_URL=https://assured-crow-74053.upstash.io
UPSTASH_REDIS_REST_TOKEN=gQAAAAAAASFFAAIncDI1NWQ5NTVkMTE3ODQ0ZDkzODRhODBjMGViNmRkN2UwMnAyNzQwNTM

# 本地开发时使用（可选）
REDIS_URL=redis://localhost:6379

# ---------- NextAuth 配置 ----------
NEXTAUTH_SECRET=hhfZEJiShGON9crLDjmmnBx4bV6wH0RrqT15p4gSYRc=
NEXTAUTH_URL=https://your-project.vercel.app

# ---------- NvwaX OIDC 认证（Public Client，与 Sprint 1 契约对齐） ----------
# ⚠️ 必须与 NvwaX IdP (account.proclaw.cc) 数据库中为 SkillHub 注册的 client_id 一致
# 任何不一致都会导致 IdP 报 invalid_client / unauthorized_client
# 公共 clientId 默认值 = skillhub-web（apps/web/lib/oidc-rp.ts 第 90 行硬编码，env 仅在 dev/staging 多 RP 时才覆盖）
SKILLHUB_OIDC_CLIENT_ID=skillhub-web
# Discovery 文档（默认指向 NvwaX 官方地址，测试/灾备时再覆盖）
SKILLHUB_OIDC_DISCOVERY_URL=https://account.proclaw.cc/.well-known/openid-configuration

# ---------- Session Cookie 跨域配置（SSO 静默登录必须） ----------
# 与主站 account.proclaw.cc 共享会话需要 SameSite=None; Secure
SESSION_COOKIE_SAMESITE=none
SESSION_COOKIE_SECURE=true

# ---------- Node 环境 ----------
NODE_ENV=production

# ---------- 可选：API Keys ----------
# OPENAI_API_KEY=sk-...
# ZHIPU_API_KEY=...
# GITHUB_TOKEN=ghp_...
# SKILLSMP_API_KEY=sk_live_...
