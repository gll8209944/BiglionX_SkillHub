# ============================================================
# 多阶段构建 - Web 应用
# 构建阶段: node:20-slim (Debian) — 确保 Prisma 生成 linux-glibc 引擎
# 生产阶段: node:20-slim (Debian) — 与构建阶段一致，无 musl/glibc 兼容问题
# ============================================================
FROM node:20-slim AS web-builder

# 安装构建依赖
RUN apt-get update && apt-get install -y --no-install-recommends \
    openssl \
    curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# 配置国内 npm 镜像加速
RUN npm config set registry https://registry.npmmirror.com

# 复制根 package.json 和 workspace 配置
COPY package*.json ./

# 安装依赖（支持 npm workspaces）
ENV npm_config_ignore_scripts=true
RUN npm install

# 复制所有源代码
COPY . .

# 重新运行 npm install 以确保 workspace 包正确链接
RUN npm install

# 构建 search-sdk（widget 依赖它）
WORKDIR /app/packages/search-sdk
RUN npm run build

# 构建 widget
WORKDIR /app/packages/widget
RUN npm run build

# 重新安装以确保 web 应用能链接到已构建的 workspace 包
WORKDIR /app
RUN npm install

# 构建 Web 应用
# NEXT_PUBLIC_* 在 next build 时写入客户端 bundle；ECS IP 部署需在构建时传入
ARG NEXT_PUBLIC_APP_URL=http://localhost:3000
ENV NEXT_PUBLIC_APP_URL=${NEXT_PUBLIC_APP_URL}

# 注意：prisma generate 需要在构建阶段完成（RUN 时有网络），生产镜像只复制产物
WORKDIR /app/apps/web
RUN npx prisma generate && npx next build

# ============================================================
# 生产阶段
# ============================================================
FROM node:20-slim AS web-production

# Prisma 运行时依赖 OpenSSL（node:20-slim 默认不含）
RUN apt-get update && apt-get install -y --no-install-recommends \
    openssl \
    curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# 健康检查
HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
    CMD curl -sf http://localhost:3000/api/health || exit 1

# 复制 package.json（包括 workspace 的）
COPY package*.json ./
COPY apps/web/package*.json ./apps/web/
COPY packages/search-sdk/package*.json ./packages/search-sdk/
COPY packages/widget/package*.json ./packages/widget/

# 仅安装生产依赖
RUN npm install --production

# 复制构建产物
COPY --from=web-builder /app/apps/web/.next ./apps/web/.next
COPY --from=web-builder /app/apps/web/public ./apps/web/public
COPY --from=web-builder /app/apps/web/next.config.* ./apps/web/
COPY --from=web-builder /app/apps/web/prisma ./apps/web/prisma

# Prisma Client（构建阶段 generate 产物，生产镜像必须复制）
COPY --from=web-builder /app/node_modules/.prisma ./node_modules/.prisma
COPY --from=web-builder /app/node_modules/@prisma/client ./node_modules/@prisma/client

# 复制已构建的 workspace 包（关键！）
COPY --from=web-builder /app/packages/search-sdk/dist ./node_modules/@skillhub/search-sdk
COPY --from=web-builder /app/packages/widget/dist ./node_modules/@skillhub/widget

EXPOSE 3000

# 切换到 apps/web 目录再启动
WORKDIR /app/apps/web
CMD ["npm", "start"]
