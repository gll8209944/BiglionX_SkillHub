# 多阶段构建 - Web 应用
FROM node:20-alpine AS web-builder

# 安装 OpenSSL（jose 需要用于 RS256 签名验证）
RUN apk add --no-cache openssl

WORKDIR /app

# 配置国内 npm 镜像加速
RUN npm config set registry https://registry.npmmirror.com

# 复制根 package.json 和 workspace 配置
COPY package*.json ./

# 安装依赖（支持 npm workspaces）
# 使用 npm_config_ignore_scripts=true 跳过所有 postinstall 脚本
# 避免 cypress 等 devDependencies 的 postinstall（如下载二进制）消耗大量磁盘空间
ENV npm_config_ignore_scripts=true
RUN npm install

# 复制所有源代码
COPY . .

# 重新运行 npm install 以确保 workspace 包正确链接
RUN npm install

# 构建 search-sdk（widget 依赖它）
WORKDIR /app/packages/search-sdk
RUN npm run build

# 构建 widget
WORKDIR /app/packages/widget
RUN npm run build

# 重新安装以确保 web 应用能链接到已构建的 workspace 包
WORKDIR /app
RUN npm install

# 构建 Web 应用（跳过 prisma db push，因为构建阶段无数据库连接）
WORKDIR /app/apps/web
RUN npx prisma generate && npx next build

# 生产阶段
FROM node:20-alpine AS web-production

WORKDIR /app

# 复制 package.json（包括 workspace 的）
COPY package*.json ./
COPY apps/web/package*.json ./apps/web/
COPY packages/search-sdk/package*.json ./packages/search-sdk/
COPY packages/widget/package*.json ./packages/widget/

# 仅安装生产依赖
RUN npm install --production

# 复制构建产物
COPY --from=web-builder /app/apps/web/.next ./.next
COPY --from=web-builder /app/apps/web/public ./public
COPY --from=web-builder /app/apps/web/next.config.* ./
COPY --from=web-builder /app/apps/web/prisma ./prisma

# 复制已构建的 workspace 包（关键！）
COPY --from=web-builder /app/packages/search-sdk/dist ./node_modules/@skillhub/search-sdk
COPY --from=web-builder /app/packages/widget/dist ./node_modules/@skillhub/widget

EXPOSE 3000

CMD ["npm", "start"]
